# ============================================================
# TrustWork — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── Soroban Smart Contract ───────────────────────────────────
# Your deployed contract address (from: soroban contract deploy ...)
# Leave empty to run in simulation/demo mode (no blockchain calls)
VITE_CONTRACT_ID=

# ── Stellar Network ──────────────────────────────────────────
VITE_STELLAR_NETWORK=testnet
VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# For mainnet, use:
# VITE_STELLAR_NETWORK=mainnet
# VITE_RPC_URL=https://soroban-rpc.stellar.org
# VITE_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015

# ── Supabase (optional — for real-time cross-device chat) ────
# Without these, chat falls back to localStorage (single device only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── IPFS File Storage (optional — for production file uploads) ──
# Without this, files are stored as local blob URLs (session only)
VITE_WEB3_STORAGE_TOKEN=
