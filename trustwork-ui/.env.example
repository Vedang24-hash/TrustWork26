# ============================================================
# TrustWork — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# The deployed TrustWork Soroban contract address on Stellar Testnet
# Deploy with: cd democontract && soroban contract deploy ...
VITE_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stellar network — "testnet" or "mainnet"
VITE_STELLAR_NETWORK=testnet

# Soroban RPC endpoint
VITE_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
